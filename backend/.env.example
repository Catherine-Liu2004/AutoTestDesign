# AutoTestDesign Backend Environment Variables
# Copy this file to .env and fill in real values

# OpenAI or DeepSeek API Key
OPENAI_API_KEY=sk-your-api-key-here

# API base URL (use https://api.deepseek.com/v1 for DeepSeek)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use (deepseek-chat for DeepSeek, gpt-4o for OpenAI)
OPENAI_MODEL=deepseek-chat

# Database URL (SQLite by default, change for PostgreSQL etc.)
DATABASE_URL=sqlite:///./autotestdesign.db

# CORS allowed origins (comma separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Debug mode (enables SQL echo)
DEBUG=false
